<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gestión de Mascotas | Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>

<body class="bg-gray-50 font-sans antialiased text-gray-900">
  <div class="container mx-auto px-4 py-8 max-w-7xl">
    
    <div class="mb-6">
      <h1 class="text-3xl font-extrabold text-gray-800 tracking-tight">Tus mascotas</h1>
      <p class="text-gray-500 text-sm">Administra las publicaciones de tus mascotas perdidas o encontradas.</p>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4 bg-white p-6 rounded-xl shadow-sm border border-gray-100">
      <div class="relative w-full md:w-96">
        <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
          <i class="fas fa-magnifying-glass"></i>
        </span>
        <input type="text" id="search" 
          class="block w-full pl-10 pr-3 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" 
          placeholder="Buscar por mascota, ID o detalle..." />
      </div>

      <button onclick="nuevomascota()" 
        class="w-full md:w-auto bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition-all shadow-lg flex items-center justify-center gap-2 transform active:scale-95">
        <i class="fas fa-plus"></i> Agregar mascota Nueva
      </button>
    </div>

    <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse" id="tabla">
          <thead>
            <tr class="bg-gray-50 text-gray-600 uppercase text-xs font-bold tracking-wider">
              <th class="px-6 py-4 border-b">Imagen</th>
              <th class="px-6 py-4 border-b">Mascota</th>
              <th class="px-6 py-4 border-b">Detalles</th>
              <th class="px-6 py-4 border-b">Categoría</th>
              <th class="px-6 py-4 border-b text-center">Estado</th>
              <th class="px-6 py-4 border-b text-center">Acciones</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {{#each data}}
            <tr class="hover:bg-blue-50/30 transition-colors group">
              <td class="px-6 py-4">
                <div class="w-14 h-14 rounded-lg overflow-hidden bg-gray-100 border border-gray-200 shadow-sm">
                  <img src="{{#if foto2}}{{foto2}}{{else}}/img/placeholder.jpg{{/if}}" 
                       alt="{{titulo}}" 
                       class="w-full h-full object-cover"
                       onerror="this.src='/img/placeholder.jpg'" />
                </div>
              </td>

              <td class="px-6 py-4">
                <div class="font-bold text-gray-800">{{titulo}}</div>
                <div class="text-[10px] font-mono text-gray-400 uppercase tracking-tighter">ID: {{id_mascota}}</div>
              </td>

              <td class="px-6 py-4">
                <p class="text-sm text-gray-600 line-clamp-1 max-w-[200px]">{{#if prod_des}}{{prod_des}}{{else}}Sin descripción{{/if}}</p>
                <span class="text-[10px] uppercase font-semibold text-blue-400">{{nota}}</span>
              </td>

              <td class="px-6 py-4">
                <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-[11px] font-bold">
                  {{cat_des}}
                </span>
              </td>

              <td class="px-6 py-4 text-center">
                {{#if visible}}
                  <a href="/destildar/{{id_mascota}}" class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-green-100 text-green-800 hover:bg-green-200 transition-colors">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-600 animate-pulse"></span> Visible
                  </a>
                {{else}}
                  <a href="/tildar/{{id_mascota}}" class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-red-100 text-red-800 hover:bg-red-200 transition-colors">
                    <span class="w-1.5 h-1.5 rounded-full bg-red-600"></span> Oculto
                  </a>
                {{/if}}
              </td>

              <td class="px-6 py-4 text-center">
                <div class="flex justify-center gap-3">
                  <a href="/modificarmascota/{{id_mascota}}" 
                    class="w-9 h-9 flex items-center justify-center text-blue-600 bg-blue-50 hover:bg-blue-600 hover:text-white rounded-lg transition-all shadow-sm" title="Modificar">
                    <i class="fas fa-edit"></i>
                  </a>
                  <a href="/mascotadel/{{id_mascota}}" 
                    onclick="return confirm('¿Estás seguro de eliminar a {{titulo}}? Esta acción no se puede deshacer.')"
                    class="w-9 h-9 flex items-center justify-center text-red-600 bg-red-50 hover:bg-red-600 hover:text-white rounded-lg transition-all shadow-sm" title="Borrar">
                    <i class="fas fa-trash"></i>
                  </a>
                </div>
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

  <script>
    function nuevomascota() {
      window.location.href = "/mascotanuevo";
    }

    $(document).ready(function () {
      // Buscador optimizado que busca en toda la fila
      $("#search").on("keyup", function () {
        const value = $(this).val().toLowerCase();
        
        $("#tabla tbody tr").filter(function () {
          // Buscamos el texto en toda la fila para flexibilidad total
          const rowText = $(this).text().toLowerCase();
          $(this).toggle(rowText.indexOf(value) > -1);
        });
      });
    });
  </script>
</body>
</html>