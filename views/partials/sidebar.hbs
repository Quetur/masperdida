<style>
    /* Mantenemos tus estilos internos de UI */
    .sidebar-inner {
        padding: 30px 20px;
        padding-top: 80px; /* Espacio para que el botón no tape el título */
    }

    .sidebar-header {
        margin-bottom: 25px;
    }

    .sidebar-title {
        font-size: 1.4rem;
        color: #1f2937;
        margin: 0;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: -0.5px;
    }

    .divider {
        border: 0;
        border-top: 2px solid #f1f5f9;
        margin: 20px 0;
    }

    .filter-section-title {
        font-size: 0.8rem;
        font-weight: 800;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        margin: 25px 0 12px 0;
    }

    /* Checkboxes Personalizados */
    .custom-check {
        display: flex;
        align-items: center;
        gap: 14px;
        cursor: pointer;
        padding: 12px;
        border-radius: 12px;
        transition: all 0.2s;
        margin-bottom: 4px;
    }

    .custom-check:hover {
        background-color: #f1f5f9;
    }

    .custom-check input {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
    }

    .box {
        width: 24px;
        height: 24px;
        border: 2.5px solid #cbd5e1;
        border-radius: 8px;
        display: inline-block;
        position: relative;
        background: white;
    }

    .custom-check input:checked + .box {
        background-color: #2563eb;
        border-color: #2563eb;
    }

    .custom-check input:checked + .box::after {
        content: "✓";
        color: white;
        font-size: 16px;
        position: absolute;
        top: 45%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-weight: 900;
    }

    .label-text {
        font-size: 1.05rem;
        color: #334155;
        font-weight: 600;
    }

    /* Spinner de carga */
    .loader-container {
        display: none;
        flex-direction: column;
        align-items: center;
        padding: 30px 0;
        margin-top: 25px;
    }

    .spinner {
        width: 35px;
        height: 35px;
        border: 4px solid #f1f5f9;
        border-top: 4px solid #2563eb;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
</style>

<aside id="sidebar" class="sidebar">
    <div class="sidebar-inner">
        <div class="sidebar-header">
            <h2 class="sidebar-title">Filtros</h2>
            <hr class="divider">
        </div>

        <form action="/" method="GET" class="filter-form" id="sidebar-form">
            <div class="checkbox-group">
                <h3 class="filter-section-title">Estado</h3>
                {{#each categorias}}
                <label class="custom-check">
                    <input type="checkbox" name="f{{this.id_categoria}}" value="{{this.id_categoria}}" 
                        {{isChecked ../filtros (concat "f" this.id_categoria)}}>
                    <span class="box"></span>
                    <span class="label-text">{{this.des}}</span>
                </label>
                {{/each}}
            </div>

            <hr class="divider">

            <div class="checkbox-group">
                <h3 class="filter-section-title">Tipo de Mascota</h3>
                {{#each tipos}}
                <label class="custom-check">
                    <input type="checkbox" name="t{{this.id_tipo}}" value="{{this.id_tipo}}" 
                        {{isChecked ../filtros (concat "t" this.id_tipo)}}>
                    <span class="box"></span>
                    <span class="label-text">{{this.des}}</span>
                </label>
                {{/each}}
            </div>

            <div id="sidebar-loader" class="loader-container">
                <div class="spinner"></div>
            </div>
        </form>
    </div>
</aside>

<button type="button" id="toggle-btn">
    <i class="fas fa-chevron-left"></i>
</button>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('sidebar-form');
        const loader = document.getElementById('sidebar-loader');
        const groups = document.querySelectorAll('.checkbox-group');

        groups.forEach(group => {
            const checkboxes = group.querySelectorAll('input[type="checkbox"]');
            checkboxes.forEach(checkbox => {
                checkbox.addEventListener('change', function () {
                    // Lógica para que se comporte como radio button solo si se MARCA
                    if (this.checked) {
                        checkboxes.forEach(cb => { if (cb !== this) cb.checked = false; });
                    }
                    
                    // Mostramos loader siempre (al tildar o destildar)
                    if (loader) loader.style.display = 'flex';
                    
                    // Sincronizamos el estado colapsado para la recarga
                    const sidebarEl = document.getElementById('sidebar');
                    if (sidebarEl) {
                        const isCollapsed = sidebarEl.classList.contains('collapsed');
                        localStorage.setItem('sidebar_collapsed', isCollapsed);
                    }
                    
                    // Ejecutamos el filtrado siempre que haya un cambio
                    form.submit();
                });
            });
        });
    });
</script>