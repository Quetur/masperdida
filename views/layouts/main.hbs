<!DOCTYPE html>
<html lang="es">

<script>
    (function() {
        const isCollapsed = localStorage.getItem('sidebar_collapsed') === 'true';
        if (isCollapsed) {
            document.documentElement.setAttribute('data-sidebar', 'collapsed');
        }
    })();
</script>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mascota Perdida</title>
    <!-- FontAwesome URL Completa -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com">
    <link rel="icon" href="/img/logo.png" type="image/png">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/main.css">

    <style>
        .btn-add-pet {
            background-color: #28a745 !important;
            color: white !important;
            border-radius: 8px;
            padding: 10px 18px;
            margin-right: 15px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
            text-decoration: none;
            font-weight: 600;
        }

        .btn-add-pet:hover {
            background-color: #218838 !important;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        @media (max-width: 600px) {
            .btn-text-nav { display: none; }
            .btn-add-pet { padding: 10px; margin-right: 5px; }
        }
    </style>
</head>

<body>
    <!-- SCRIPT DE PRE-CARGA -->
    <script>
        (function() {
            const isCollapsed = localStorage.getItem('sidebar_collapsed') === 'true';
            if (isCollapsed) {
                document.documentElement.classList.add('sidebar-hidden-init');
            }
        })();
    </script>

    <header class="top-navbar">
<div class="nav-left">
    <a href="/" style="display: flex; align-items: center; text-decoration: none; color: inherit;">
        <img src="/img/logo.png" alt="Logo" class="nav-logo"
            style="width: 100px; height: 100px; object-fit: contain;">
        
        <span class="brand-name" style="color: #2563eb; font-weight: 800; font-size: 1.5rem; margin-left: 10px; letter-spacing: -0.5px;">
            Ayudame a volver a casa
        </span>
    </a>
</div>

        <div class="nav-right" style="display: flex; align-items: center;">
            {{#if user}}
                <!-- SECCIÓN PARA USUARIO AUTENTICADO (Leído desde res.locals.user) -->
                <div id="adminContainer" class="admin-menu-container" style="display: flex;">
                    <input type="checkbox" id="menu-toggle">
                    <label for="menu-toggle" class="nav-btn-professional">
                        <i class="fas fa-user-circle"></i>
                        <span id="nombreUsuarioMenu" class="user-name-text">{{user.nombre}}</span>
                    </label>
                    <ul class="admin-dropdown">
                        <li><a href="/mascotacambia">Tus Mascotas</a></li>
                        <li><a href="/">Editar tu perfil</a></li>
                        <li class="menu-divider"></li>
                        <li><a href="/logout" id="btnSalirMenu">Salir</a></li>
                    </ul>
                </div>
            {{else}}
                <!-- SECCIÓN PARA USUARIO NO AUTENTICADO O TOKEN VENCIDO -->
                <a href="/signin" id="btnAcceso" class="nav-btn-professional">INGRESAR</a>
            {{/if}}
        </div>
    </header>

    <div class="layout-container">
        {{#unless hideSidebar}}
            {{> sidebar }}
        {{/unless}}

        <main id="main-content" class="content">
            {{{body}}}
        </main>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const ui = {
                sidebar: document.getElementById('sidebar'),
                toggleBtn: document.getElementById('toggle-btn'),
                content: document.getElementById('main-content'),
                btnSalirMenu: document.getElementById('btnSalirMenu')
            };

            // --- PERSISTENCIA DEL SIDEBAR ---
            if (ui.sidebar && ui.toggleBtn) {
                const isCollapsed = localStorage.getItem('sidebar_collapsed') === 'true';
                
                if (isCollapsed) {
                    ui.sidebar.classList.add('collapsed');
                    ui.content.classList.add('expanded');
                    ui.toggleBtn.innerText = '➔';
                } else {
                    ui.toggleBtn.innerText = '⬅';
                }

                ui.toggleBtn.addEventListener('click', (e) => {
                    e.preventDefault();
                    const nowCollapsed = ui.sidebar.classList.toggle('collapsed');
                    ui.content.classList.toggle('expanded');
                    localStorage.setItem('sidebar_collapsed', nowCollapsed);
                    ui.toggleBtn.innerText = nowCollapsed ? '➔' : '⬅';
                });
            }

            // --- LÓGICA DE CIERRE DE SESIÓN (Opcional si usas ruta /logout) ---
            if (ui.btnSalirMenu) {
                ui.btnSalirMenu.addEventListener('click', () => {
                    // Limpiamos rastros locales por seguridad
                    sessionStorage.clear();
                    localStorage.removeItem('token_acceso');
                    localStorage.removeItem('nombre');
                });
            }
        });
    </script>
</body>
</html>
