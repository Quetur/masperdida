<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Mascota Perdida</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="icon" href="/img/logo.png" type="image/png">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/main.css">

    <style>
        /* Estilo para el botón Acerca de nosotros discreto */
        .btn-about-minimal {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: transparent;
            border: none;
            padding: 5px 10px;
            color: #64748b; /* Gris discreto */
            font-family: 'Inter', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            text-transform: uppercase;
            letter-spacing: 0.02em;
        }

        .btn-about-minimal span {
            text-decoration: underline;
            text-underline-offset: 3px;
        }

        .btn-about-minimal i {
            font-size: 1.1rem;
            color: #94a3b8;
        }

        .btn-about-minimal:hover {
            color: #1e293b;
        }

        .btn-about-minimal:hover i {
            color: #2563eb; /* El logo se pone azul al pasar el mouse */
        }
    </style>

    <script>
        (function () {
            const storageValue = localStorage.getItem('sidebar_collapsed');
            const isCollapsed = storageValue === null ? true : storageValue === 'true';
            
            if (isCollapsed) {
                document.documentElement.setAttribute('data-sidebar', 'collapsed');
                localStorage.setItem('sidebar_collapsed', 'true');
            } else {
                document.documentElement.setAttribute('data-sidebar', 'expanded');
            }
        })();
    </script>
</head>

<body class="sidebar-logic">

    <header class="top-navbar">
        <div class="nav-left">
            <a href="/" class="brand-link">
                <img src="/img/logo.png" alt="Logo" class="nav-logo">
                <span class="brand-name">Ayudame a volver a casa</span>
            </a>
        </div>

        <div class="nav-right">
            <button id="btnAbout" class="btn-about-minimal">
                <i class="fas fa-info-circle"></i> 
                <span>Acerca de nosotros</span>
            </button>
     <style>
                    /* Lógica de visibilidad con tu checkbox actual */
                    #menu-toggle:checked ~ .admin-dropdown {
                        display: block !important;
                        opacity: 1;
                        transform: translateY(0);
                        pointer-events: auto;
                    }

                    #menu-toggle:not(:checked) ~ .admin-dropdown {
                        display: none;
                        opacity: 0;
                        transform: translateY(-10px);
                        pointer-events: none;
                    }

                    /* Animación para la flechita */
                    #menu-toggle:checked ~ label .fa-chevron-down {
                        transform: rotate(180deg);
                    }
                </style>
            {{#if user}}

<div class="admin-menu-container">
    <input type="checkbox" id="menu-toggle" hidden>
    
    <label for="menu-toggle" class="nav-btn-professional">
        <i class="fas fa-user-circle"></i>
        <span class="user-name-text">{{user.nombre}}</span>
        <i class="fas fa-chevron-down" style="font-size: 0.8rem;"></i>
    </label>

    <ul class="admin-dropdown">
        <li style="padding: 5px 15px; font-size: 10px; font-weight: 800; color: #94a3b8; text-transform: uppercase;">Mi Cuenta</li>
        
        <li>
            <a href="/mascotacambia">
                <i class="fas fa-paw"></i> Tus Mascotas
            </a>
        </li>
        
        <li>
            <a href="/perfil/editar">
                <i class="fas fa-user-edit"></i> Editar Perfil
            </a>
        </li>

        <li class="menu-divider"></li>

        <li>
            <a href="/logout" class="logout-link">
                <i class="fas fa-sign-out-alt"></i> Salir
            </a>
        </li>
    </ul>
</div>


           
            {{else}}
            <a href="/signin" id="btnAcceso" class="nav-btn-professional">INGRESAR</a>
            {{/if}}
        </div>
    </header>

    <div class="layout-container">
        {{#unless hideSidebar}}
        {{> sidebar }}
        {{/unless}}

        <main id="main-content" class="content {{#if hideSidebar}}full-width{{/if}}">
            {{{body}}}
        </main>
    </div>

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const sidebar = document.getElementById('sidebar');
            const content = document.getElementById('main-content');
            const toggleBtn = document.getElementById('toggle-btn');

            if (sidebar && toggleBtn) {
                const isCollapsed = document.documentElement.getAttribute('data-sidebar') === 'collapsed';

                const setSidebarState = (collapsed) => {
                    if (collapsed) {
                        sidebar.classList.add('collapsed');
                        content.classList.add('expanded');
                        toggleBtn.innerHTML = '<i class="fas fa-chevron-right"></i>';
                    } else {
                        sidebar.classList.remove('collapsed');
                        content.classList.remove('expanded');
                        toggleBtn.innerHTML = '<i class="fas fa-chevron-left"></i>';
                    }
                };

                setSidebarState(isCollapsed);

                toggleBtn.addEventListener('click', (e) => {
                    e.preventDefault();
                    const nowCollapsed = !sidebar.classList.contains('collapsed');
                    localStorage.setItem('sidebar_collapsed', nowCollapsed);
                    document.documentElement.setAttribute('data-sidebar', nowCollapsed ? 'collapsed' : 'expanded');
                    setSidebarState(nowCollapsed);
                });
            }

            const btnAbout = document.getElementById('btnAbout');
            if (btnAbout) {
                btnAbout.addEventListener('click', () => {
                     window.location.href = '/about';
                });
            }

            const btnSalir = document.getElementById('btnSalirMenu');
            if (btnSalir) {
                btnSalir.addEventListener('click', () => {
                    sessionStorage.clear();
                    localStorage.removeItem('token_acceso');
                });
            }
        });
    </script>
</body>
</html>