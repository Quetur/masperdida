<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="/css/home.css">

<style>
    :root { --primary-blue: #2563eb; --overlay: rgba(15, 23, 42, 0.9); }
    
    #map-general { height: 600px; width: 100%; background: #f1f5f9; }
    
    #modal-mapa-general, #detalle-pop-up {
        display: none; position: fixed; inset: 0;
        background: var(--overlay); z-index: 10000;
        justify-content: center; align-items: center; padding: 20px;
        backdrop-filter: blur(4px);
    }

    .modal-content-white {
        background: white; border-radius: 15px; overflow: hidden;
        display: flex; flex-direction: column; width: 95%; max-width: 1100px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .hidden { display: none !important; }

    /* Aceleración por GPU para los iconos */
    .custom-pet-icon { 
        transition: transform 0.15s cubic-bezier(0.4, 0, 0.2, 1); 
        will-change: transform;
    }
    .custom-pet-icon:hover { transform: scale(1.2); z-index: 1000 !important; }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 20px;
        margin-top: 20px;
    }
</style>

<section class="main-content-area">
    <header class="content-header">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 10px;">
            <h1 style="margin:0;">Catálogo de Mascotas</h1>
            <button type="button" onclick="abrirMapaGeneral()" class="btn-mapa-cercano" style="background: var(--primary-blue); color: white; padding: 12px 24px; border-radius: 10px; cursor: pointer; border: none; font-weight: bold; transition: opacity 0.2s;">
                <i class="fas fa-map-marked-alt"></i> VER MAPA CERCANO
            </button>
        </div>

        <div class="search-container">
            <input type="text" id="search-input" placeholder="Buscar por nombre o categoría..." style="width: 100%; padding: 14px; border-radius: 10px; border: 1.5px solid #e2e8f0; font-size: 16px; outline: none;">
        </div>
        <p style="margin-top: 10px; color: #64748b;">Mostrando <strong id="count" style="color: var(--primary-blue);">{{mascotas.length}}</strong> mascotas</p>
    </header>

    <div class="product-grid" id="product-grid">
        {{#each mascotas}}
        <article class="product-card" data-title="{{this.titulo}}" data-category="{{this.cat_des}}">
            <div class="product-image" style="aspect-ratio: 1/1; overflow: hidden; background: #f1f5f9;">
                <img src="{{#if this.foto2}}{{this.foto2}}{{else}}/img/placeholder.jpg{{/if}}" alt="{{this.titulo}}" loading="lazy" style="width:100%; height:100%; object-fit: cover;">
            </div>
            <div class="product-info" style="padding: 15px;">
                <h3 style="margin:0 0 5px 0;">{{this.titulo}}</h3>
                <p style="font-size: 14px; color: #64748b; margin-bottom: 15px;">{{this.direccion}}</p>
                <button type="button" class="btn-view" 
                    onclick="mostrarPopUp(this)" 
                    data-titulo="{{this.titulo}}"
                    data-foto="{{#if this.foto2}}{{this.foto2}}{{else}}/img/placeholder.jpg{{/if}}"
                    data-descripcion="{{this.des}}" 
                    data-direccion="{{this.direccion}}" 
                    data-lat="{{this.latitud}}"
                    data-lng="{{this.longitud}}"
                    data-category="{{this.cat_des}}"
                    data-tipo="{{this.tipo}}"
                    data-sexo="{{this.sexo}}"
                    data-raza="{{this.raza}}"
                    data-nota="{{this.nota}}"
                    style="width: 100%; padding: 10px; border: 1px solid var(--primary-blue); background: transparent; color: var(--primary-blue); border-radius: 8px; font-weight: 600; cursor: pointer;">
                    Ver Datos
                </button>
            </div>
        </article>
        {{/each}}
    </div>
</section>

<div id="modal-mapa-general">
    <div class="modal-content-white">
        <div style="padding: 15px 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #f1f5f9;">
            <h3 style="margin:0;">📍 Mascotas en el mapa</h3>
            <button onclick="cerrarMapaGeneral()" style="font-size: 32px; border: none; background: none; cursor: pointer; color: #94a3b8;">&times;</button>
        </div>
        <div id="map-general"></div>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="/js/home.js"></script>