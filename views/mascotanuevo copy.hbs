<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nueva Mascota</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="/src/mascotanuevo.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com" />
  <style>
    .hidden { display: none; }
    /* Animación para los radio buttons */
    .peer:checked + div { border-width: 2px; transform: scale(1.02); box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
    /* Suavizado de transiciones */
    select, input, textarea { transition: all 0.2s ease-in-out; }
  </style>
</head>

<body class="bg-gray-200 p-4 md:p-10 font-sans">
  <div class="max-w-2xl mx-auto bg-white rounded-xl shadow-2xl overflow-hidden border border-gray-300">

    <!-- Header -->
    <div class="bg-blue-600 px-6 py-4 flex items-center gap-3">
      <i class="fas fa-plus-circle text-white text-xl"></i>
      <h2 class="text-white font-bold text-xl tracking-wide">Publicar Nueva Mascota</h2>
    </div>

    <!-- FORMULARIO -->
    <form action="/mascota_nuevo_graba" method="POST" enctype="multipart/form-data" class="p-8 space-y-8" id="formMascota">

      <!-- Campos Ocultos Técnicos -->
      <div style="display: none;">
        <input type="hidden" name="visible" value="1">
        <input type="hidden" name="orden" value="1">
        <input type="hidden" name="fecha" id="fecha_actual">
        <input type="hidden" name="precio1" value="0">

        
    
      </div>
      <input type="hidden" name="id_usuario" value="{{userid}}">

      <!-- SECCIÓN 1: CLASIFICACIÓN (DISEÑO DISTANCIADO) -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        
        <!-- Categoría -->
        <div class="md:col-span-2 bg-white p-4 rounded-xl border border-gray-100 shadow-sm">
          <label class="block text-[11px] font-extrabold text-blue-700 uppercase mb-2 tracking-widest">
            ¿Qué le pasó a la mascota?
          </label>
          <select name="id_categoria" id="id_categoria" 
            class="w-full border border-blue-300 p-3.5 rounded-lg bg-blue-100 text-gray-800 focus:ring-2 focus:ring-blue-600 focus:bg-white hover:border-blue-500 outline-none cursor-pointer font-semibold" required>
            <option value="" disabled selected>-- Que le paso a la mascota ? --</option>
            {{#each cat}}
              <option value="{{this.id_categoria}}">{{this.des}}</option>
            {{/each}}
          </select>
        </div>

        <!-- Tipo -->
        <div class="bg-white p-4 rounded-xl border border-gray-100 shadow-sm">
          <label class="block text-[11px] font-extrabold text-blue-700 uppercase mb-2 tracking-widest">
            Tipo de Mascota
          </label>
          <select name="id_tipo" id="id_tipo" 
            class="w-full border border-blue-300 p-3.5 rounded-lg bg-blue-100 text-gray-800 focus:ring-2 focus:ring-blue-600 focus:bg-white hover:border-blue-500 outline-none cursor-pointer font-semibold" required>
            <option value="" disabled selected>-- ¿Qué animalito es? --</option>
            {{#each tipo}}
              <option value="{{this.id_tipo}}">{{this.des}}</option>
            {{/each}}
          </select>
        </div>

        <!-- Raza -->
        <div class="bg-white p-4 rounded-xl border border-gray-100 shadow-sm">
          <label class="block text-[11px] font-extrabold text-blue-700 uppercase mb-2 tracking-widest">
            Raza
          </label>
          <select name="id_raza" id="id_raza" 
            class="w-full border border-blue-300 p-3.5 rounded-lg bg-blue-100 text-gray-800 focus:ring-2 focus:ring-blue-600 focus:bg-white hover:border-blue-500 outline-none disabled:opacity-50 font-semibold" required disabled>
            <option value="" disabled selected>-- Elija la raza  --</option>
            {{#each raza}}
              <option value="{{this.id_raza}}" data-tipo="{{this.id_tipo}}" class="raza-option hidden">{{this.des}}</option>
            {{/each}}
          </select>
        </div>
      </div>

      <!-- SECCIÓN 2: SEXO Y FECHAS -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 bg-gray-50 p-6 rounded-2xl border border-gray-200">
        <!-- Sexo -->
        <div>
          <label class="block text-[10px] font-bold text-gray-500 uppercase mb-3 tracking-widest text-center">Sexo</label>
          <div class="flex gap-3">
            <label class="flex-1">
              <input type="radio" name="sexo" value="Macho" class="hidden peer" required>
              <div class="text-center p-3 border border-blue-300 rounded-xl cursor-pointer bg-blue-100 peer-checked:bg-blue-700 peer-checked:text-white peer-checked:border-blue-700 hover:bg-blue-200 text-blue-900 font-bold text-sm">
                <i class="fas fa-mars mr-1"></i> Macho
              </div>
            </label>
            <label class="flex-1">
              <input type="radio" name="sexo" value="Hembra" class="hidden peer">
              <div class="text-center p-3 border border-pink-300 rounded-xl cursor-pointer bg-pink-100 peer-checked:bg-pink-600 peer-checked:text-white peer-checked:border-pink-600 hover:bg-pink-200 text-pink-900 font-bold text-sm">
                <i class="fas fa-venus mr-1"></i> Hembra
              </div>
            </label>
          </div>
        </div>

        <!-- Fechas Intercambiables -->
        <div id="contenedor-fechas">
          <div id="div_fecha_perdida">
            <label class="block text-[10px] font-bold text-gray-500 uppercase mb-3 tracking-widest text-center">Fecha del Suceso</label>
            <input name="fecha_perdida" id="input_fecha_perdida" type="date" 
              class="w-full border border-blue-300 p-3 rounded-xl outline-none focus:ring-2 focus:ring-blue-600 bg-blue-100 focus:bg-white hover:border-blue-500 text-gray-800 font-semibold shadow-inner">
          </div>
          
          <div id="div_fecha_nacimiento" class="hidden">
            <label class="block text-[10px] font-bold text-blue-700 uppercase mb-3 tracking-widest text-center">Fecha de Nacimiento</label>
            <input name="fecha_nacimiento" id="input_fecha_nacimiento" type="date" value="1900-01-01" 
              class="w-full border border-blue-400 p-3 rounded-xl outline-none focus:ring-2 focus:ring-blue-600 bg-blue-100 focus:bg-white hover:border-blue-500 text-gray-800 font-semibold shadow-inner">
          </div>
        </div>
      </div>

      <!-- SECCIÓN 3: IMAGEN Y TEXTOS -->
      <div class="flex flex-col md:flex-row gap-8 border-t border-gray-100 pt-8">
        <!-- Foto -->
        <div class="w-full md:w-1/2 flex flex-col items-center">
          <label class="block text-[10px] font-bold text-gray-500 uppercase mb-4 tracking-widest">Foto de Perfil</label>
          <div class="w-full aspect-square bg-blue-100 rounded-2xl overflow-hidden border-2 border-dashed border-blue-300 flex items-center justify-center relative group hover:bg-blue-50 transition-colors">
            <img id="img_preview" class="w-full h-full object-cover hidden" />
            <div id="placeholder" class="text-blue-400 text-center">
              <i class="fas fa-camera text-6xl mb-3"></i>
              <p class="text-xs font-black uppercase">Subir Foto</p>
            </div>
          </div>
          <button type="button" onclick="document.getElementById('foto2').click()" 
            class="mt-4 w-full bg-blue-600 text-white font-bold py-2.5 rounded-full hover:bg-blue-700 shadow-lg active:scale-95 transition-all">
            Seleccionar Imagen
          </button>
          <input type="file" name="foto2" id="foto2" accept="image/*" class="hidden" />
        </div>

        <!-- Campos de Texto -->
        <div class="w-full md:w-1/2 space-y-5">
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-1.5 ml-1">Si sabes el nombre</label>
            <input name="titulo" type="text" 
              class="w-full border border-blue-300 p-3.5 rounded-xl bg-blue-100 focus:bg-white focus:ring-2 focus:ring-blue-600 hover:border-blue-500 outline-none font-semibold" placeholder="Ej: Busco a mi mascota" required>
          </div>
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-1.5 ml-1">Descripción detallada</label>
            <textarea name="des" rows="4" 
              class="w-full border border-blue-300 p-3.5 rounded-xl bg-blue-100 focus:bg-white focus:ring-2 focus:ring-blue-600 hover:border-blue-500 outline-none resize-none font-semibold" placeholder="Señas, collar, comportamiento..." required></textarea>
          </div>
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-1.5 ml-1">Zona y Contacto</label>
            <input name="nota" type="text" 
              class="w-full border border-blue-300 p-3.5 rounded-xl bg-blue-100 focus:bg-white focus:ring-2 focus:ring-blue-600 hover:border-blue-500 outline-none font-semibold" placeholder="Barrio y Celular" required>
          </div>
        </div>
      </div>

      <!-- BOTONES FINALES -->
      <div class="flex flex-col md:flex-row gap-4 pt-6">
        <button type="submit" 
          class="flex-[2] bg-emerald-600 hover:bg-emerald-700 text-white font-black py-5 rounded-2xl shadow-xl transition-all active:scale-95 text-lg uppercase tracking-widest">
          <i class="fas fa-check-circle mr-2"></i> Publicar Ahora
        </button>
        <button type="button" onclick="window.location='/'" 
          class="flex-1 bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold py-5 rounded-2xl transition-all uppercase text-sm">
          Cancelar
        </button>
      </div>
    </form>
  </div>


</body>
</html>
