<link rel="stylesheet" href="/css/home.css">

<section class="main-content-area">
    <header class="content-header">
        <h1>Catálogo de Mascotas</h1>
        <div class="search-container">
            <div class="search-form">
                <input type="text" id="search-input" placeholder="Buscar por nombre o categoría...">
                <span class="search-icon">🔍</span>
            </div>
        </div>
        <p class="results-count">Mostrando <strong id="count">{{mascotas.length}}</strong> mascotas</p>
    </header>

    <div class="product-grid" id="product-grid">
        {{#each mascotas}}
        <article class="product-card" data-title="{{this.titulo}}" data-category="{{this.cat_des}}">
            <div class="product-image">
                <img src="{{#if this.foto2}}{{this.foto2}}{{else}}/img/placeholder.jpg{{/if}}" alt="{{this.titulo}}">
                <span class="product-badge badge-estado">{{this.cat_des}}</span>
            </div>
            <div class="product-info">
                <h3>{{this.titulo}}</h3>
                <p class="description">{{this.des}}</p>
            </div>
            <footer class="product-footer">
                <div class="location-info">
                    <i class="fas fa-map-marker-alt"></i> {{this.nota}}
                </div>
                <!-- Botón que activa el Pop-up -->
                <button type="button" class="btn-view" onclick="mostrarPopUp(this)" data-titulo="{{this.titulo}}"
                    data-foto="{{this.foto2}}" data-descripcion="{{this.des}}" data-contacto="{{this.nota}}">
                    <i class="fas fa-eye"></i> Ver Datos
                </button>
            </footer>
        </article>
        {{/each}}
    </div>

    <!-- VENTANA POP-UP (Oculta por defecto) -->
    <!-- VENTANA POP-UP (Versión Pro Compacta) -->
    <div id="detalle-pop-up"
        style="display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.75); backdrop-filter: blur(4px); z-index: 9999; justify-content: center; align-items: center; padding: 20px;">
        <div
            style="background: white; border-radius: 12px; max-width: 750px; width: 100%; position: relative; display: flex; flex-wrap: wrap; overflow: hidden; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);">

            <!-- Botón Cerrar Minimalista -->
            <button onclick="cerrarPopUp()"
                style="position: absolute; top: 12px; right: 12px; background: white; border: 1px solid #e2e8f0; font-size: 18px; cursor: pointer; border-radius: 50%; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; color: #64748b; transition: all 0.2s; z-index: 10;">&times;</button>

            <!-- Columna Imagen -->
            <div style="flex: 1; min-width: 300px; background: #f8fafc;">
                <img id="pop-img" src="" alt="Mascota"
                    style="width: 100%; height: 100%; min-height: 350px; object-fit: cover;">
            </div>

            <!-- Columna Contenido -->
            <div
                style="flex: 1.2; min-width: 300px; padding: 30px; display: flex; flex-direction: column; justify-content: center;">
                <span
                    style="text-transform: uppercase; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.05em; color: #2563eb; margin-bottom: 8px;">Detalle
                    de la mascota</span>
                <h2 id="pop-titulo"
                    style="color: #0f172a; margin: 0 0 16px 0; font-size: 1.5rem; font-weight: 800; border-bottom: 2px solid #f1f5f9; padding-bottom: 12px;">
                </h2>

                <div id="pop-descripcion"
                    style="color: #475569; line-height: 1.5; font-size: 0.95rem; margin-bottom: 20px; max-height: 120px; overflow-y: auto;">
                </div>

                <div id="pop-contacto"
                    style="font-weight: 600; color: #1e293b; font-size: 0.9rem; background: #f1f5f9; padding: 12px 16px; border-radius: 8px; border-left: 4px solid #2563eb; margin-bottom: 24px;">
                </div>

                <button onclick="cerrarPopUp()"
                    style="background: #1e293b; color: white; border: none; padding: 10px; border-radius: 6px; cursor: pointer; font-size: 0.9rem; font-weight: 600; transition: background 0.3s;"
                    onmouseover="this.style.background='#334155'" onmouseout="this.style.background='#1e293b'">
                    Entendido
                </button>
            </div>
        </div>
    </div>

    <div id="no-results" class="no-results" style="display: none; text-align: center; padding: 50px;">
        <i class="fas fa-search-minus" style="font-size: 3rem; color: #cbd5e1;"></i>
        <p style="margin-top: 15px; color: #64748b;">No se encontraron mascotas.</p>
    </div>
</section>

<script>
    function mostrarPopUp(btn) {
        const modal = document.getElementById('detalle-pop-up');

        // Cargar los datos dinámicos
        document.getElementById('pop-titulo').innerText = btn.getAttribute('data-titulo');
        document.getElementById('pop-img').src = btn.getAttribute('data-foto') || '/img/placeholder.jpg';
        document.getElementById('pop-descripcion').innerText = btn.getAttribute('data-descripcion');
        document.getElementById('pop-contacto').innerHTML = '<i class="fas fa-info-circle"></i> Info: ' + btn.getAttribute('data-contacto');

        // Mostrar como flex para centrar el contenido
        modal.style.display = 'flex';
        // Bloquear scroll del fondo
        document.body.style.overflow = 'hidden';
    }

    function cerrarPopUp() {
        document.getElementById('detalle-pop-up').style.display = 'none';
        // Restaurar scroll
        document.body.style.overflow = 'auto';
    }

    // Cerrar al hacer clic fuera del cuadro blanco
    window.onclick = function (event) {
        const modal = document.getElementById('detalle-pop-up');
        if (event.target == modal) {
            cerrarPopUp();
        }
    }
</script>