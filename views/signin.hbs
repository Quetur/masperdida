<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Acceso - Mascota Perdida</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/signin.css">

    <style>
        /* ESTO FUERZA EL ANCHO COMPLETO Y OCULTA EL SIDEBAR SI EXISTIERA */
        #sidebar {
            display: none !important;
        }

        #main-content {
            margin-left: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #f8fafc; /* Color de fondo suave para que no quede blanco puro */
        }

        /* Aseguramos que el body no tenga scroll horizontal */
        body {
            overflow-x: hidden;
        }

        /* Ajuste para que la card no se pegue a los bordes en móvil */
        .login-card {
            margin: 20px auto;
        }
    </style>
</head>
<body>

<div class="login-card">
    <div class="brand-header">
        <h1>Mascota<span>Perdida</span></h1>
        <div class="divider"></div>
        <p class="subtitle-acceso">Acceso</p>
    </div>

    <form id="formlogin">
        <div class="mb-3">
            <label class="form-label">CELULAR O EMAIL</label>
            <div class="input-wrapper">
                <input type="text" id="login_input" class="form-control-custom" placeholder="Dato de contacto">
                <input type="hidden" id="login_final" name="celular">
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label">CONTRASEÑA</label>
            <div class="input-wrapper">
                <input type="password" id="pass" name="pass" class="form-control-custom" placeholder="••••••••">
                <button type="button" class="btn-toggle-eye toggle-pass" data-target="#pass">👁️</button>
            </div>
        </div>

        <button type="submit" class="btn-submit">INGRESAR</button>

        <div class="text-center mt-3">
            <a href="#" class="forgot-link" onclick="abrirModalRecuperar()">¿Olvidaste tu contraseña?</a>
        </div>
    </form>

    <div class="register-section">
        <p>¿No tienes cuenta?</p>
        <a href="/registro" class="btn-register">REGISTRARME</a>
    </div>
</div>

<div id="modalRecuperar" class="modal-overlay">
    <div class="modal-content">
        <h3>Recuperar cuenta</h3>
        <p>Ingresá tu Email o WhatsApp para recibir un PIN de seguridad.</p>
        <div class="mb-4 text-start">
            <label class="form-label">DESTINO</label>
            <div class="input-wrapper">
                <input type="text" id="destino_recuperar_mask" class="form-control-custom" placeholder="Email o Celular">
                <input type="hidden" id="destino_recuperar_final">
            </div>
        </div>
        <button type="button" class="btn-submit" onclick="solicitarPinRecuperacion()">ENVIAR PIN</button>
        <button type="button" class="btn-cancelar" onclick="cerrarModal('#modalRecuperar')">Volver</button>
    </div>
</div>

<div id="modalPIN" class="modal-overlay">
    <div class="modal-content">
        <h3>Verifica tu Identidad</h3>
        <p>Enviamos un código a: <strong id="txt_destino_rec"></strong></p>
        <div class="pin-container">
            <input type="text" maxlength="1" class="pin-in" inputmode="numeric">
            <input type="text" maxlength="1" class="pin-in" inputmode="numeric">
            <input type="text" maxlength="1" class="pin-in" inputmode="numeric">
            <input type="text" maxlength="1" class="pin-in" inputmode="numeric">
        </div>
        <input type="hidden" id="pin_completo">
        <input type="hidden" id="intentos_input" value="5">
        <input type="hidden" id="destino_hidden">
        <button type="button" class="btn-submit" onclick="validarPinRecuperacion()">VALIDAR CÓDIGO</button>
        <button type="button" class="btn-cancelar" onclick="cerrarModal('#modalPIN')">Cancelar</button>
    </div>
</div>

<div id="modalNuevaPass" class="modal-overlay">
    <div class="modal-content">
        <h3>Nueva Contraseña</h3>
        <div class="text-start mb-3">
            <label class="form-label">CONTRASEÑA NUEVA</label>
            <input type="password" id="nueva_pass" class="form-control-custom">
        </div>
        <div class="text-start mb-4">
            <label class="form-label">CONFIRMAR</label>
            <input type="password" id="confirmar_pass" class="form-control-custom">
            <div id="msg-error-pass" style="display:none; color:red; font-size:12px;">❌ No coinciden</div>
        </div>
        <button type="button" class="btn-submit" onclick="confirmarCambioFinal()">ACTUALIZAR Y ENTRAR</button>
    </div>
</div>

<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/signin.js"></script>
</body>
</html>