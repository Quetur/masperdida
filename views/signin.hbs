<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Acceso - Mascota Perdida</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    {{!-- Tu archivo CSS externo --}}
    <link rel="stylesheet" href="/css/signin.css">
</head>
<body>

<div class="login-card">
    <div class="brand-header">
        <h1>Mascota<span>Perdida</span></h1>
        <div class="divider"></div>
        <p class="subtitle-acceso">Acceso</p>
    </div>

    <form id="formlogin" method="post" action="/login">
        <div class="mb-3">
            <label class="form-label">CELULAR O EMAIL</label>
            <div class="input-wrapper">
                <input type="text" id="login_input" class="form-control-custom" placeholder="Dato de contacto">
                <input type="hidden" id="login_final" name="celular">
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label">CONTRASEÑA</label>
            <div class="input-wrapper">
                <input type="password" id="pass" name="pass" class="form-control-custom" placeholder="••••••••">
                <button type="button" class="btn-toggle-eye toggle-pass" data-target="#pass">👁️</button>
            </div>
        </div>

        <button type="button" class="btn-submit" onclick="ingresar()">INGRESAR</button>
        <a href="#" class="link-recuperar" onclick="abrirRecuperacion()">¿Olvidaste tu contraseña?</a>
    </form>

    <div class="register-section">
        <p>¿No tienes una cuenta?</p>
        <a href="/registro" class="btn-register">CREAR CUENTA NUEVA</a>
    </div>
</div>

{{!-- MODALES --}}
<div id="modal-recuperar" class="modal-overlay">
    <div class="modal-content">
        <h3>Recuperar Acceso</h3>
        <p>Ingresa tu celular o email registrado para enviarte un PIN.</p>
        <div class="input-wrapper mb-3">
            <input type="text" id="destino_recuperar_mask" class="form-control-custom" placeholder="Dato de contacto">
            <input type="hidden" id="destino_recuperar_final">
        </div>
        <button type="button" class="btn-submit" onclick="enviarPinRecuperacion()">ENVIAR CÓDIGO</button>
        <button type="button" onclick="cerrarRecuperacion()" class="btn-cancelar">Cancelar</button>
    </div>
</div>

<div id="modalPIN" class="modal-overlay">
    <div class="modal-content">
        <h3>Verifica tu Identidad</h3>
        <p>Enviamos un código a: <strong id="txt_destino"></strong></p>
        <div class="pin-container">
            <input type="text" maxlength="1" class="pin-in" inputmode="numeric">
            <input type="text" maxlength="1" class="pin-in" inputmode="numeric">
            <input type="text" maxlength="1" class="pin-in" inputmode="numeric">
            <input type="text" maxlength="1" class="pin-in" inputmode="numeric">
        </div>
        <input type="hidden" id="pin_completo">
        <input type="hidden" id="intentos_input" value="5">
        <input type="hidden" id="destino_hidden">
        <p class="intentos-text">Te quedan <span id="contador_visual">5</span> intentos.</p>
        <button type="button" onclick="procesarValidacionPin()" class="btn-submit">VALIDAR CÓDIGO</button>
    </div>
</div>

<div id="modal-reset-password" class="modal-overlay">
    <div class="modal-content">
        <h3>Nueva Contraseña</h3>
        <p>Crea una nueva contraseña de acceso.</p>
        
        <div class="text-start mb-3">
            <label class="form-label">CONTRASEÑA NUEVA</label>
            <div class="input-wrapper">
                <input type="password" id="nueva_pass" class="form-control-custom" placeholder="Mínimo 6 caracteres">
                <button type="button" class="btn-toggle-eye toggle-pass" data-target="#nueva_pass">👁️</button>
            </div>
        </div>

        <div class="text-start mb-4">
            <label class="form-label">CONFIRMAR CONTRASEÑA</label>
            <div class="input-wrapper">
                <input type="password" id="confirmar_pass" class="form-control-custom" placeholder="Repite la contraseña">
                <button type="button" class="btn-toggle-eye toggle-pass" data-target="#confirmar_pass">👁️</button>
            </div>
            <div id="msg-error-pass" class="text-error" style="display: none;">
                ❌ Las contraseñas no coinciden
            </div>
        </div>

        <button type="button" class="btn-submit" onclick="confirmarCambioFinal()">ACTUALIZAR Y ENTRAR</button>
    </div>
</div>

{{!-- Scripts --}}
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
{{!-- Tu archivo JS externo --}}
<script src="/js/signin.js"></script>

</body>
</html>