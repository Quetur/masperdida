<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Acceso - Mascota Perdida</title>
    
    <!-- 1. SCRIPTS CORREGIDOS -->
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
        :root {
            --primary-color: #0d6efd;
            --primary-hover: #0b5ed7;
            --bg-gradient: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-gradient);
            min-height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            background: #ffffff;
            width: 90%;
            max-width: 400px;
            padding: 35px 25px;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
        }

        .brand-header { text-align: center; margin-bottom: 30px; }
        .brand-header h1 { color: var(--primary-color); font-weight: 800; font-size: 1.7rem; margin: 0; }
        .brand-header .divider { width: 40px; height: 3px; background: var(--primary-color); margin: 10px auto; border-radius: 2px; }
        .brand-header p { color: #6c757d; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }

        .form-label { font-size: 0.75rem; font-weight: 700; color: #495057; margin-bottom: 6px; display: block; }

        .input-wrapper { position: relative; margin-bottom: 20px; }

        .form-control-custom {
            width: 100%;
            height: 50px;
            padding: 10px 45px 10px 15px;
            font-size: 1rem;
            border-radius: 10px;
            border: 1px solid #ced4da;
            box-sizing: border-box;
            transition: border-color 0.2s;
        }

        .form-control-custom:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.1);
        }

        .btn-toggle-eye {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            font-size: 1.3rem;
            z-index: 10;
            padding: 5px;
        }

        .btn-submit {
            width: 100%;
            background: var(--primary-color);
            color: white;
            border: none;
            height: 50px;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-submit:hover { background: var(--primary-hover); transform: translateY(-1px); }

        .register-section {
            text-align: center;
            margin-top: 25px;
            padding-top: 20px;
            border-top: 1px solid #eee;
        }

        .btn-register {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 50px;
            background: transparent;
            color: var(--primary-color);
            border: 2px solid var(--primary-color);
            border-radius: 10px;
            font-size: 0.9rem;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.2s;
        }

        .btn-register:hover {
            background: rgba(13, 110, 253, 0.05);
        }

        .swal2-title-custom {
            font-family: 'Inter', sans-serif !important;
            font-weight: 700 !important;
            color: #495057 !important;
        }
    </style>
</head>
<body>

<div class="login-card">
    <div class="brand-header">
        <h1>Mascota Perdida</h1>
        <div class="divider"></div>
        <p>Acceso al Sistema</p>
    </div>

    <form id="formlogin" method="post" action="/login">
        <div class="mb-3">
            <label class="form-label">CELULAR</label>
            <div class="input-wrapper">
                <!-- Se cambió id para mayor claridad y se agregó placeholder correcto -->
                <input type="tel" id="celular_mask" class="form-control-custom" placeholder="(XX) XXXX-XXXX" autocomplete="off" inputmode="tel" maxlength="15">
                <input type="hidden" id="celular_final" name="celular">
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label">CONTRASEÑA</label>
            <div class="input-wrapper">
                <input type="password" id="pass" name="pass" class="form-control-custom" placeholder="••••••••">
                <button type="button" id="btn-toggle" class="btn-toggle-eye">👁️</button>
            </div>
        </div>

        <button type="button" id="btn-ingresar" class="btn-submit" onclick="ingresar()">
            INGRESAR
        </button>
    </form>

    <div class="register-section">
        <p>¿No tienes una cuenta aún?</p>
        <a href="/registro" class="btn-register">
            CREAR CUENTA NUEVA
        </a>
    </div>
</div>

<script>
    const Toast = Swal.mixin({
        confirmButtonColor: '#0d6efd',
        customClass: { title: 'swal2-title-custom' }
    });

    $(document).ready(function () {
        // MÁSCARA MEJORADA (XX) XXXX-XXXX
        $("#celular_mask").on("input", function (e) {
            let valor = e.target.value.replace(/\D/g, ""); // Solo números
            let formateado = "";

            if (valor.length > 0) {
                formateado = "(" + valor.substring(0, 2);
                if (valor.length > 2) {
                    formateado += ") " + valor.substring(2, 6);
                }
                if (valor.length > 6) {
                    formateado += "-" + valor.substring(6, 10);
                }
            }

            e.target.value = formateado;
            $("#celular_final").val(valor); // El hidden guarda solo los números
        });

        // Ver contraseña corregido
        $('#btn-toggle').on('click', function(e) {
            const input = $('#pass');
            const type = input.attr('type') === 'password' ? 'text' : 'password';
            input.attr('type', type);
            $(this).text(type === 'password' ? '👁️' : '🙈');
        });

        // Detectar si el servidor mandó alerta de registro exitoso
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('registro') === 'exitoso') {
            Toast.fire({
                icon: 'success',
                title: '🐾 ¡Genial!',
                text: 'Cuenta creada con éxito. Ya puedes entrar.'
            });
        }
    });

    function ingresar() {
        const celRaw = $("#celular_final").val();
        const passVal = $("#pass").val();

        if (!celRaw || celRaw.length < 10) {
            Toast.fire({ 
                icon: 'warning', 
                title: '🐾 ¡Ups!', 
                text: 'Ingresa un número de celular válido.',
                timer: 2500, 
                showConfirmButton: false 
            });
            return;
        }
        if (!passVal) {
            Toast.fire({ 
                icon: 'warning', 
                title: '🐾 ¡Falta algo!', 
                text: 'La contraseña es obligatoria.',
                timer: 2000, 
                showConfirmButton: false 
            });
            return;
        }

        $("#btn-ingresar").prop("disabled", true).html('<span class="spinner-grow spinner-grow-sm"></span> ENTRANDO...');
        $("#formlogin").submit();
    }
</script>

</body>
</html>
