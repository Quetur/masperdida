<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Modificar Mascota - {{pro.titulo}}</title>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <style>
    #map {
      height: 450px;
      width: 100%;
      border-radius: 12px;
      display: block;
    }
    .hidden { display: none !important; }
    .animate-in { animation: fadeIn 0.4s ease-out; }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    /* Mantiene el cuerpo de la página con un scroll limpio */
    body { min-height: 100vh; }
  </style>
</head>

<body class="bg-gray-200 p-4 md:p-10 font-sans">
  <div class="max-w-2xl mx-auto bg-white rounded-xl shadow-2xl overflow-hidden border border-gray-300">

    <div class="bg-blue-600 px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <i class="fas fa-edit text-white text-xl"></i>
        <h2 class="text-white font-bold text-xl tracking-wide">Modificar Publicación</h2>
      </div>
      <span class="text-blue-200 text-xs font-mono font-bold">ID: {{pro.id_mascota}}</span>
    </div>

    <div class="flex h-1.5 w-full bg-gray-100">
      <div id="dot-1" class="bg-yellow-400 w-1/2 transition-all duration-500"></div>
      <div id="dot-2" class="bg-gray-300 w-1/2 transition-all duration-500"></div>
    </div>

    <form action="/Mascotamodi/{{pro.id_mascota}}" method="POST" enctype="multipart/form-data" 
          class="p-8 min-h-[700px] flex flex-col" id="formModifica">

      <div style="display: none;">
        <input type="hidden" name="id_mascota" value="{{pro.id_mascota}}">
        <input type="hidden" name="visible" value="{{pro.visible}}">
        <input type="hidden" id="latitud_input" name="latitud" value="{{pro.latitud}}">
        <input type="hidden" id="longitud_input" name="longitud" value="{{pro.longitud}}">
      </div>

      <div id="step-1" class="space-y-6 animate-in flex-grow flex flex-col">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="md:col-span-2 bg-white p-4 rounded-xl border border-gray-100 shadow-sm">
            <label class="block text-[11px] font-extrabold text-blue-700 uppercase mb-2 tracking-widest">Estado de la publicación</label>
            <select name="id_categoria" id="id_categoria" class="w-full border border-blue-300 p-3.5 rounded-lg bg-blue-100 font-semibold outline-none focus:bg-white" required>
              {{#each cat}}
                <option value="{{this.id_categoria}}" {{#if this.id_categoria_mascota}}selected{{/if}}>{{this.des}}</option>
              {{/each}}
            </select>
          </div>

          <div class="bg-white p-4 rounded-xl border border-gray-100 shadow-sm">
            <label class="block text-[11px] font-extrabold text-blue-700 uppercase mb-2 tracking-widest">Tipo de mascota</label>
            <select name="id_tipo" id="id_tipo" class="w-full border border-blue-300 p-3.5 rounded-lg bg-blue-100 font-semibold outline-none" required>
              {{#each tipo}}
                <option value="{{this.id_tipo}}" {{#if this.id_tipo_mascota}}selected{{/if}}>{{this.des}}</option>
              {{/each}}
            </select>
          </div>

          <div class="bg-white p-4 rounded-xl border border-gray-100 shadow-sm">
            <label class="block text-[11px] font-extrabold text-blue-700 uppercase mb-2 tracking-widest">Raza</label>
            <select name="id_raza" id="id_raza" class="w-full border border-blue-300 p-3.5 rounded-lg bg-blue-100 font-semibold outline-none" required>
              {{#each subcat}}
                <option value="{{this.id_raza}}" data-tipo="{{this.id_tipo}}" {{#if this.id_raza_mascota}}selected{{/if}}>{{this.des}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="flex flex-col md:flex-row gap-8 bg-gray-50 p-6 rounded-2xl border border-gray-200">
          <div class="w-full md:w-1/2 flex flex-col items-center">
            <div class="w-full aspect-square bg-white rounded-2xl border-2 border-dashed border-blue-200 flex items-center justify-center relative overflow-hidden shadow-inner">
                <img id="img_preview" src="{{pro.foto2}}" class="w-full h-full object-contain p-2 transition-all duration-300" />
            </div>
            <button type="button" onclick="document.getElementById('input_foto').click()" class="mt-4 w-full bg-blue-600 text-white font-bold py-2 rounded-full text-sm hover:bg-blue-700 transition-colors shadow-md">
              <i class="fas fa-camera mr-2"></i>Cambiar Foto
            </button>
            <input type="file" name="foto2" id="input_foto" accept="image/*" class="hidden" />
          </div>

          <div class="w-full md:w-1/2 space-y-4">
              <div>
                  <label class="block text-[11px] font-extrabold text-blue-700 uppercase mb-1.5 tracking-widest ml-1">Nombre / Título</label>
                  <input name="titulo" type="text" value="{{pro.titulo}}" required
                        class="w-full border border-blue-300 p-3.5 rounded-xl bg-white outline-none font-semibold focus:ring-2 focus:ring-blue-400 transition-all">
              </div>

              <div>
                  <label class="block text-[11px] font-extrabold text-blue-700 uppercase mb-1.5 tracking-widest ml-1">Descripción</label>
                  <textarea name="des" rows="3" required
                            class="w-full border border-blue-300 p-3.5 rounded-xl bg-white outline-none resize-none font-semibold focus:ring-2 focus:ring-blue-400 transition-all">{{pro.des}}</textarea>
              </div>

              <div>
                  <label class="block text-[11px] font-extrabold text-blue-700 uppercase mb-1.5 tracking-widest ml-1">Nota Interna</label>
                  <input name="nota" type="text" value="{{pro.nota}}"
                        class="w-full border border-blue-300 p-3.5 rounded-xl bg-white outline-none font-semibold italic">
              </div>
          </div>
        </div>

        <button type="button" onclick="cambiarPaso(2)" class="mt-auto w-full bg-blue-600 text-white font-black py-5 rounded-2xl shadow-lg uppercase tracking-widest hover:bg-blue-700 transition-all">
          Siguiente: Ubicación <i class="fas fa-arrow-right ml-2"></i>
        </button>
      </div>

<div id="step-2" class="hidden space-y-6">
  <h3 class="text-xl font-bold text-gray-800 text-center">¿Dónde se perdió?</h3>
  
  <div class="bg-white rounded-2xl shadow-lg border-2 border-blue-200 overflow-hidden relative">
    <div id="map"></div>
  </div>

  <input type="hidden" name="latitud" id="latitud_input" value="{{pro.latitud}}">
  <input type="hidden" name="longitud" id="longitud_input" value="{{pro.longitud}}">

  <div class="space-y-4 bg-gray-50 p-4 rounded-2xl border border-gray-200">
      <div>
          <label class="block text-xs font-black text-blue-600 uppercase mb-1">DIRECCION DETECTADA</label>
          <input type="text" id="ubicacion_calle" name="calle" value="{{pro.direccion}}" class="w-full p-3 border-2 border-gray-100 rounded-xl outline-none focus:border-blue-500">
      </div>
      <div class="grid grid-cols-2 gap-4">
          <input type="text" id="ubicacion_ciudad" name="ciudad" placeholder="Ciudad" class="p-3 border-2 border-gray-100 rounded-xl outline-none focus:border-blue-500">
          <input type="text" id="ubicacion_provincia" name="provincia" placeholder="Provincia" class="p-3 border-2 border-gray-100 rounded-xl outline-none focus:border-blue-500">
      </div>
      <input type="hidden" id="ubicacion_pais" name="pais" value="Argentina">
  </div>

  <div class="flex gap-4">
    <button type="button" onclick="cambiarPaso(1)" class="flex-1 bg-gray-300 text-gray-800 py-4 rounded-2xl font-bold uppercase text-sm">Volver</button>
    <button type="submit" class="flex-[2] bg-blue-700 text-white font-black py-4 rounded-2xl uppercase shadow-xl hover:bg-blue-800 transition-all">
      Guardar Cambios
    </button>
  </div>
</div>





    </form>
  </div>

    </form>
  </div>

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="/js/mascotamodifica.js"></script>

  <script>
    function cambiarPaso(paso) {
      const s1 = document.getElementById('step-1');
      const s2 = document.getElementById('step-2');
      const d1 = document.getElementById('dot-1');
      const d2 = document.getElementById('dot-2');

      if (paso === 2) {
        s1.classList.add('hidden');
        s2.classList.remove('hidden');
        d1.classList.replace('bg-yellow-400', 'bg-blue-600');
        d2.classList.replace('bg-gray-300', 'bg-yellow-400');
        
        // Refrescar mapa para evitar errores de carga en divs inicialmente ocultos
        if (typeof map !== 'undefined') {
          setTimeout(() => {
              map.invalidateSize();
          }, 300);
        }
      } else {
        s2.classList.add('hidden');
        s1.classList.remove('hidden');
        d1.classList.replace('bg-blue-600', 'bg-yellow-400');
        d2.classList.replace('bg-yellow-400', 'bg-gray-300');
      }
      window.scrollTo(0, 0);
    }
  </script>
</body>
</html>