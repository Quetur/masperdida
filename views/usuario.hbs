<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link rel="stylesheet" href="/css/usuario.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
</head>

<body>

    <main class="register-card" id="main_layout">
        <header class="brand-header">
            <h1>Mascotas<span>Perdidas</span></h1>
            <div class="divider"></div>
            <p>Registro de Comunidad</p>
        </header>

        <section class="registration-form">
            <div class="input-wrapper">
                <label class="form-label" for="nombre">Nombre Completo</label>
                <input type="text" id="nombre" class="form-control-custom" placeholder="Ej. Juan Pérez" required>
            </div>

            <div class="input-wrapper">
                <label class="form-label">Validar cuenta por:</label>
                <div class="contact-selector">
                    <input type="radio" name="metodo_contacto" id="opt_ws" value="ws" checked style="display: none;">
                    <label for="opt_ws" class="contact-btn"><span>📱 WhatsApp</span></label>

                    <input type="radio" name="metodo_contacto" id="opt_email" value="email" style="display: none;">
                    <label for="opt_email" class="contact-btn"><span>📧 Email</span></label>
                </div>
            </div>

            <div id="wrapper_celular" class="input-wrapper">
                <label class="form-label" for="celular_mask">Número de WhatsApp</label>
                <input type="text" id="celular_mask" class="form-control-custom" placeholder="(11) 1234-5678"
                    inputmode="numeric">
                <input type="hidden" id="celular_final">
            </div>

            <div id="wrapper_email" class="input-wrapper" style="display: none;">
                <label class="form-label" for="email">Correo Electrónico</label>
                <input type="email" id="email" class="form-control-custom" placeholder="ejemplo@correo.com">
            </div>

            <div id="checking-user"
                style="display: none; flex-direction: column; align-items: center; justify-content: center; padding: 15px; margin: 10px 0; background: rgba(243, 244, 246, 0.7); border-radius: 8px; border: 1px dashed #3498db;">
                <div class="spinner-large"></div>
                <span
                    style="font-size: 1.1rem; font-weight: 700; color: #2c3e50; margin-top: 10px; font-family: 'Inter', sans-serif;">
                    CHEQUEO DE EXISTENCIA...
                </span>
            </div>

            <div class="input-wrapper">
                <label class="form-label" for="pass">Contraseña</label>
                <div class="password-wrapper">
                    <input type="password" id="pass" class="form-control-custom" placeholder="Mínimo 6 caracteres"
                        disabled>
                    <button type="button" id="btn-toggle" class="btn-toggle-eye">👁️</button>
                </div>
            </div>

            <button type="button" id="btn-registrar" class="btn-submit" onclick="validarRegistro(event)" disabled>
                REGISTRARME AHORA
            </button>
        </section>
    </main>

    <div id="modalPIN" class="modal-overlay">
        <div class="modal-content">
            <h3>Verifica tu Identidad</h3>
            <p>Enviamos un código a: <strong id="txt_destino"></strong></p>

            <div class="pin-container">
                <input type="text" maxlength="1" class="pin-in" inputmode="numeric" pattern="[0-9]*">
                <input type="text" maxlength="1" class="pin-in" inputmode="numeric" pattern="[0-9]*">
                <input type="text" maxlength="1" class="pin-in" inputmode="numeric" pattern="[0-9]*">
                <input type="text" maxlength="1" class="pin-in" inputmode="numeric" pattern="[0-9]*">
            </div>

            <input type="hidden" id="pin_completo">
            <input type="hidden" id="intentos_input">
            <input type="hidden" id="destino_hidden">
            <input type="hidden" id="metodo_hidden">

            <p class="attempts-text">Te quedan <span id="contador_visual">5</span> intentos.</p>

            <button type="button" onclick="enviarPin()" class="btn-verify">VALIDAR CÓDIGO</button>
            <button type="button" class="btn-close" onclick="cancelarRegistro()">Cancelar</button>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/usuario.js"></script>

</body>

</html>