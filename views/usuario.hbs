<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link rel="stylesheet" href="/css/usuario.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

    <main class="register-card" id="main_layout">
        <header class="brand-header">
            <h1>Mascotas<span>Perdidas</span></h1>
            <div class="divider"></div>
            <p>Registro de Comunidad</p>
        </header>

        <section class="registration-form">
            <div class="input-wrapper">
                <label class="form-label" for="nombre">Nombre Completo</label>
                <input type="text" id="nombre" name="nombre" class="form-control-custom" placeholder="Ej. Juan Pérez" required>
            </div>

            <div class="input-wrapper">
                <label class="form-label">Validar cuenta por:</label>
                <div class="contact-selector">
                    <input type="radio" name="metodo_contacto" id="opt_ws" value="ws" checked style="display: none;">
                    <label for="opt_ws" class="contact-btn">
                        <span>📱 WhatsApp</span>
                    </label>

                    <input type="radio" name="metodo_contacto" id="opt_email" value="email" style="display: none;">
                    <label for="opt_email" class="contact-btn">
                        <span>📧 Email</span>
                    </label>
                </div>
            </div>

            <div id="wrapper_celular" class="input-wrapper">
                <label class="form-label" for="celular_mask">Número de WhatsApp</label>
                <input type="text" id="celular_mask" class="form-control-custom" placeholder="(11) 1234-5678">
                <input type="hidden" id="celular_final" name="celular">
            </div>

            <div id="wrapper_email" class="input-wrapper" style="display: none;">
                <label class="form-label" for="email">Correo Electrónico</label>
                <input type="email" id="email" name="email" class="form-control-custom" placeholder="ejemplo@correo.com">
            </div>

            <div class="input-wrapper">
                <label class="form-label" for="pass">Contraseña</label>
                <div style="position: relative;">
                    <input type="password" id="pass" name="pass" class="form-control-custom" placeholder="Mínimo 6 caracteres" disabled>
                    <button type="button" id="btn-toggle" class="btn-toggle-eye">👁️</button>
                </div>
            </div>

            <button type="button" id="btn-registrar" class="btn-submit" onclick="validarRegistro()" disabled>
                REGISTRARME AHORA
            </button>
        </section>
    </main>

    <div id="modalPIN" class="modal-overlay {{#if showModal}}active{{/if}}">
        <div class="modal-content">
            <h3>Verifica tu Identidad</h3>
            <p>Hemos enviado un código a: <strong id="txt_destino">{{destino}}</strong></p>

            <div class="pin-container">
                <input type="text" maxlength="1" class="pin-in">
                <input type="text" maxlength="1" class="pin-in">
                <input type="text" maxlength="1" class="pin-in">
                <input type="text" maxlength="1" class="pin-in">
            </div>

            <input type="hidden" id="pin_completo">
            <input type="hidden" id="intentos_input" value="{{#if intentos}}{{intentos}}{{else}}5{{/if}}">
            <input type="hidden" id="destino_hidden" value="{{destino}}">
            <input type="hidden" id="metodo_hidden" value="{{metodo_contacto}}">

            {{#if error_pin}}
                <span class="error-text">❌ Código incorrecto.</span>
            {{/if}}

            <p class="attempts-text">
                Te quedan <span id="contador_visual">{{#if intentos}}{{intentos}}{{else}}5{{/if}}</span> intentos.
            </p>

            <button type="button" onclick="enviarPin()" class="btn-verify">VALIDAR CÓDIGO</button>
           <button type="button" class="btn-close" onclick="cancelarRegistro()">Cancelar</button>
        </div>
    </div>

    <script>
        // Datos del servidor sin espacios en las etiquetas Handlebars
        const SERVER_DATA = {
            showModal: {{#if showModal}}true{{else}}false{{/if}},
            destino: "{{destino}}",
            metodo: "{{metodo_contacto}}",
            errorPin: {{#if error_pin}}true{{else}}false{{/if}},
            intentos: {{#if intentos}}{{intentos}}{{else}}5{{/if}}
        };

        // Corrección de Accesibilidad y Foco
        document.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('modalPIN');
            if (modal && modal.classList.contains('active')) {
                // Quitamos aria-hidden del contenedor principal si existe
                const layout = document.getElementById('main_layout');
                if (layout) layout.removeAttribute('aria-hidden');
                
                // Forzamos el foco al primer input del PIN
                const inputs = document.querySelectorAll('.pin-in');
                if (inputs.length > 0) {
                    setTimeout(() => inputs[0].focus(), 100);
                }
            }
        });
    </script>
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/usuario.js"></script>

</body>
</html>