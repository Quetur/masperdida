{{!-- views/about.hbs --}}

<style>
    .about-wrapper {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
        animation: fadeInAbout 0.8s ease-out;
    }

    .about-hero {
        text-align: center;
        margin-bottom: 60px;
    }

    .hero-title {
        font-size: 3rem;
        font-weight: 900;
        color: #0f172a;
        margin-bottom: 15px;
        letter-spacing: -1.5px;
    }

    .hero-subtitle {
        font-size: 1.25rem;
        color: #64748b;
        max-width: 800px;
        margin: 0 auto;
        line-height: 1.6;
    }

    .mission-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
        margin-bottom: 80px;
    }

    .info-card {
        background: white;
        padding: 45px 35px;
        border-radius: 28px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
        border: 1px solid #f1f5f9;
        transition: all 0.3s ease;
    }

    .info-card:hover {
        transform: translateY(-10px);
    }

    .icon-circle {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 25px;
        font-size: 1.8rem;
    }

    .icon-circle.amarillo { background: #fef9c3; color: #ca8a04; border: 3px solid #fde047; }
    .icon-circle.azul { background: #dbeafe; color: #2563eb; border: 3px solid #bfdbfe; }
    .icon-circle.rojo { background: #fee2e2; color: #ef4444; border: 3px solid #fecaca; }

    .contact-container {
        background: white;
        border-radius: 35px;
        padding: 60px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
        border: 1px solid #f1f5f9;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 60px;
        align-items: center;
    }

    .form-box {
        background: #f8fafc;
        padding: 40px;
        border-radius: 25px;
        border: 1px solid #e2e8f0;
    }

    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; font-weight: 800; margin-bottom: 10px; color: #475569; }

    .form-control {
        width: 100%;
        padding: 15px;
        border: 2px solid #e2e8f0;
        border-radius: 15px;
        font-family: inherit;
    }

    @keyframes fadeInAbout {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 992px) {
        .contact-grid { grid-template-columns: 1fr; }
        .hero-title { font-size: 2.5rem; }
    }
</style>

<div class="about-wrapper">
    <header class="about-hero">
        <h1 class="hero-title">Unidos por los que no tienen voz</h1>
        <p class="hero-subtitle">
            Somos un grupo de profesionales en tecnología y voluntarios comprometidos con nuestros hermanos de cuatro patas. 
        </p>
    </header>

    <section class="mission-grid">
        <div class="info-card">
            <div class="icon-circle amarillo"><i class="fas fa-laptop-code"></i></div>
            <h3>Desarrollo Solidario</h3>
            <p>Arquitectos de software dedicados a crear una plataforma rápida e intuitiva.</p>
        </div>

        <div class="info-card">
            <div class="icon-circle azul"><i class="fas fa-shield-heart"></i></div>
            <h3>Tu Mascota a Salvo</h3>
            <p>Centralizamos reportes para acelerar los rescates y reencuentros.</p>
        </div>

        <div class="info-card">
            <div class="icon-circle rojo"><i class="fas fa-hand-holding-heart"></i></div>
            <h3>Red Comunitaria</h3>
            <p>Fomentamos la colaboración entre vecinos, veterinarias y protectoras.</p>
        </div>
    </section>

    <section class="contact-container">
        <div class="contact-grid">
            <div class="contact-text">
                <h2>¿Tenés una duda?</h2>
                <p>Escribinos y nos pondremos en contacto (11) 7060 - 9536 </p>
                <div style="margin-top: 20px; font-weight: 700; color: #2563eb;">
                    <i class="fas fa-paper-plane"></i> contacto@ayudameavolver.com.ar
                </div>
            </div>

            <div class="form-box">
                <form id="aboutContactForm">
                    <div class="form-group">
                        <label>Nombre Completo</label>
                        <input type="text" class="form-control" placeholder="Ej: Juan Pérez" required>
                    </div>
                    <div class="form-group">
                        <label>Correo</label>
                        <input type="email" class="form-control" placeholder="tu@email.com" required>
                    </div>
                    <div class="form-group">
                        <label>Mensaje</label>
                        <textarea class="form-control" rows="4" placeholder="¿Cómo podemos ayudarte?" required></textarea>
                    </div>
                    <button type="submit" class="nav-btn-professional" style="width: 100%; justify-content: center; height: 65px; border: none;">
                        ENVIAR MENSAJE
                    </button>
                </form>
            </div>
        </div>
    </section>
</div>